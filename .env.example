# ── Supabase + Vercel config (copy to .env locally; set in Vercel per project) ──
# Never commit real values. .env is gitignored.

# Control plane — one Supabase project (the vendor brain).
#   Migrations (setup script): DIRECT connection string, port 5432
#   Runtime (apps on Vercel):  TRANSACTION POOLER string, port 6543
CONTROL_PLANE_DATABASE_URL=postgres://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# Tenant datastore — for the fast test, ONE tenant pinned by slug.
# Set on the tenant-app project only.
TENANT_SLUG=demo
TENANT_DATABASE_URL=postgres://postgres:PASSWORD@db.yyyy.supabase.co:6543/postgres

# Admin console gate (set on the admin Vercel project).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Later — Supabase Management API driver (auto-provision tenant projects).
# Not needed for the first manual two-project test.
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_ORG_ID=...
# DATASTORE_DRIVER=supabase
