{
  "name": "hr-saas",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "postgres": "^3.4.5"
  },
  "scripts": {
    "provision": "node scripts/provision-tenant.mjs",
    "worker": "node services/provisioner/src/worker.mjs",
    "migrate:tenants": "node scripts/migrate-tenants.mjs",
    "redeploy": "node scripts/redeploy-tenant.mjs",
    "test:unit": "tsx --test packages/rbac/src/rbac.test.ts packages/entitlements/src/entitlements.test.ts packages/schema-engine/src/validate.test.ts packages/payroll/src/payroll.test.ts",
    "test:isolation": "tsx scripts/test-isolation.mts",
    "teardown": "node scripts/teardown-tenant.mjs",
    "docker:build:app": "docker build -f docker/app.Dockerfile -t hr-app:dev .",
    "dev:app": "npm run dev --workspace apps/app",
    "dev:marketing": "npm run dev --workspace apps/marketing",
    "dev:admin": "npm run dev --workspace apps/admin",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
